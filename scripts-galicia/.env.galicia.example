# Copy to scripts-galicia/.env.galicia and fill in. This file is gitignored.

# --- Copernicus Data Space (Sentinel Hub Process API) OAuth client ----------
# Create at https://shapps.dataspace.copernicus.eu/dashboard/ -> User settings -> OAuth clients
SH_CLIENT_ID=
SH_CLIENT_SECRET=

# --- Region ----------------------------------------------------------------
# REGION is the metadata tag written to the DB; ACOM_NAME is the autonomous
# community polygon used for clipping (spain_autonomous_communities.acom_name).
REGION=Galicia
ACOM_NAME=Galicia

# --- Docker access ---------------------------------------------------------
# If the cron/runtime user is NOT in the docker group, use sudo:
#   DOCKER="sudo docker"
DOCKER=docker

# --- Optional Sentinel request tuning --------------------------------------
# Pixel grid for the Galicia request (defaults are set in the download script).
# WIDTH=2000
# HEIGHT=2000
# MAX_CLOUD=30
# MOSAICKING_ORDER=mostRecent

# --- Optional bbox override (skip DB-derived bbox) -------------------------
# MIN_LON=-9.40 MIN_LAT=41.80 MAX_LON=-6.70 MAX_LAT=43.85
